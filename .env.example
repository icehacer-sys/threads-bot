# Copy this file to .env and fill in the two secrets below.
# .env is gitignored. Never commit real tokens.

# --- Required secrets ---

# Anthropic API key (https://console.anthropic.com/ -> API Keys)
ANTHROPIC_API_KEY=

# Threads long-lived access token for @mdnoteslab
# Generate it with `npm run token` (see README). Not needed for `npm run demo`.
THREADS_ACCESS_TOKEN=

# --- Only needed to GENERATE the token above, via `npm run token`. ---
# From your Meta app's Threads use case. Use the THREADS app id/secret.
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
# A redirect URI registered in the app. A page on a domain you own works well,
# e.g. https://mednoteslab.com/ . After approving you copy the ?code= from the URL bar.
THREADS_REDIRECT_URI=https://mednoteslab.com/

# --- Optional tuning (safe defaults shown) ---

# Model. Default claude-sonnet-4-6 (best balance of wit and cost).
# Cheaper: claude-haiku-4-5. Overkill: claude-opus-4-8.
# BOT_MODEL=claude-sonnet-4-6

# Only reply within the first N hours of a post. 0 = no time limit (default).
# BOT_WINDOW_HOURS=0

# Max number of recent posts to scan per run.
# BOT_MAX_POSTS=10

# Which unanswered comments to reply to first: "recent" (newest) or "engagement" (best-effort).
# BOT_SELECTION=recent

# Hard ceiling on replies per 24h (Threads API allows ~250 published/day; stay well under).
# BOT_DAILY_CAP=100

# Hard cap on total replies per post (running total across runs).
# BOT_PER_POST_CAP=100

# Auto-correct/teach on wrong medical guesses (matches your style, but generates
# medical statements). Set to "off" to leave those for you to handle by hand.
# BOT_EDUCATIONAL=on

# Auto-post your written answer breakdown once a post is this many hours old.
# You still pin it manually (the API can't pin). BOT_ANSWER_SPOILER=on blurs
# everything after the first line; default off posts the answer in full.
# BOT_ANSWER=on
# BOT_ANSWER_DELAY_HOURS=1
# BOT_ANSWER_SPOILER=off

# Required to actually post in live mode. Must equal "yes" or live mode refuses to post.
# BOT_CONFIRM_LIVE=

# Only act on the single newest post (cleanest for a once-a-day challenge).
# BOT_NEWEST_ONLY=off

# Send the post's X-ray image to the model (vision) so replies can see the case.
# BOT_VISION=on

# Active-hours gate for live posting (timezone-aware; the cloud runner is UTC).
# Only run when local time in BOT_ACTIVE_TZ is within [START, END). Wraps past
# midnight, so 20 -> 0 = 8 PM until midnight. 0 -> 24 = always on. Empty TZ = always on.
# BOT_ACTIVE_TZ=Africa/Cairo
# BOT_ACTIVE_START=0
# BOT_ACTIVE_END=24
